# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# MISTRAL_API_KEY: Required for the in-app AI Pharmacist chatbot (Mistral AI).
# Sign up at https://console.mistral.ai and create a key.
# Drop the real key into a local `.env` file (NEVER commit it).
# Exposed at runtime via BuildConfig.MISTRAL_API_KEY by the secrets-gradle-plugin.
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY_HERE
